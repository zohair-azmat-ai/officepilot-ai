# ─────────────────────────────────────────────────────────────────────────────
# OfficePilot AI — Environment Configuration Template
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Root folder that contains year/month sub-folders for quotations
# Example: G:\NEW DATA 2021\DRIVE\Quotation
QUOTATION_BASE_PATH=G:\YOUR\QUOTATION\FOLDER

# Absolute path to your Excel template file
TEMPLATE_PATH=templates\quotation_template.xlsx

# Server
APP_HOST=127.0.0.1
APP_PORT=8000

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Step 1: Create a bot via @BotFather on Telegram → copy the token below
# Step 2: Get your chat ID by messaging @userinfobot on Telegram
# Step 3: Set TELEGRAM_ENABLED=true to activate

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_CHAT_IDS=your_chat_id_here
